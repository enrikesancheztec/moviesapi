# Images (already built locally)
API_IMAGE=moviesapi:latest
FRONTEND_IMAGE=movies-app:latest

# Ports exposed on host
MYSQL_PORT_HOST=13306
API_PORT_HOST=18080
FRONTEND_PORT_HOST=13000

# Host path for MySQL data (stored on macOS)
MYSQL_DATA_DIR=./docker/mysql-data

# MySQL settings
MYSQL_DATABASE=movies
MYSQL_USER=movies_user
MYSQL_PASSWORD=change_me_password
MYSQL_ROOT_PASSWORD=change_me_root_password

# API settings
JPA_DDL_AUTO=update
JPA_SHOW_SQL=true
APP_CORS_ALLOWED_ORIGINS=http://localhost:13000
APP_CORS_ALLOW_CREDENTIALS=false
JWT_TOOLS_KEY=change_me_jwt_key

# Frontend settings
NEXT_PUBLIC_API_URL=http://localhost:18080
